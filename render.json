{
  "services": [
    {
      "type": "web",
      "runtime": "node",
      "name": "healthradius",
      "plan": "free",
      "buildCommand": "npm run render-build",
      "startCommand": "npm run render-start",
      "envVars": [
        { "key": "NODE_ENV", "value": "production" },
        { "key": "NODE_VERSION", "value": "20" }
      ]
    }
  ]
}
