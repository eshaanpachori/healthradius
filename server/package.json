{
  "name": "server",
  "version": "1.0.0",
  "description": "HealthRadius Backend Server",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed": "node src/seeds/seed.js",
    "seed:reset": "node src/seeds/seed.js --reset",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.js --quiet",
    "format": "prettier --write src/**/*.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.2.1",
    "morgan": "^1.10.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4",
    "vitest": "^1.3.1"
  }
}
