{
  "name": "healthradius-workspace",
  "version": "1.0.0",
  "description": "HealthRadius - Nearby Hospital Discovery and Trust Platform",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "seed": "npm run seed --workspace=server",
    "seed:reset": "npm run seed:reset --workspace=server",
    "test": "npm run test --workspace=server && npm run test --workspace=client",
    "test:server": "npm run test --workspace=server",
    "test:client": "npm run test --workspace=client",
    "test:e2e": "npm run test:e2e --workspace=client",
    "lint": "npm run lint --workspace=server && npm run lint --workspace=client",
    "format": "npm run format --workspace=server && npm run format --workspace=client",
    "build": "npm run build --workspace=client",
    "start": "npm run start --workspace=server",
    "render-build": "npm install --include=dev && npm run build --workspace=client",
    "render-start": "npm run start --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
